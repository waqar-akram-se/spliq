{
  "version": 2,
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "env": [
    "GEMINI_API_KEY"
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
